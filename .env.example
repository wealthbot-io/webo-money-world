# Webo's Money World — local config. Copy to .env and fill in.
# NEVER commit a real key. .env is gitignored.

# Required: server-side Anthropic key (held by the PHP proxy, never sent to the browser)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
WEBO_MODEL=claude-sonnet-4-5
WEBO_RATE_MAX=30
WEBO_RATE_WINDOW=600
