# Webo's Money World — config. Copy to .env (gitignored) for local `vercel dev`,
# and set the same vars in the Vercel project dashboard for deploys.
# NEVER commit a real key.

# Required: server-side Anthropic key (held by the /api/ask function, never sent to the browser)
ANTHROPIC_API_KEY=sk-ant-...

# Optional
WEBO_MODEL=claude-sonnet-4-5
WEBO_MODERATION_MODEL=claude-haiku-4-5
WEBO_RATE_MAX=30             # per-session (per browser) requests per window
WEBO_RATE_WINDOW=600         # window in seconds
WEBO_IP_RATE_MAX=150         # per-IP backstop per window (shared IPs: schools/homes)
WEBO_GLOBAL_DAILY_MAX=15000  # daily cost ceiling in MODEL CALLS (~3 per request) ~= 5000 requests/day
WEBO_GLOBAL_FALLBACK_MAX=300 # per-instance ceiling during a KV outage (NOT the full budget)
WEBO_MAX_BODY_BYTES=16384    # reject request bodies larger than this before parsing
# NOTE: the only unbypassable cost backstop is a hard monthly spend cap set at the
# Anthropic billing/console layer - set one before any public launch.

# Optional: anonymous cross-device progress codes (/api/progress, needs KV below)
WEBO_PROGRESS_TTL_DAYS=90   # how long a saved progress code lives
WEBO_PROGRESS_RATE_MAX=30   # per-IP save+restore requests per window
WEBO_PROGRESS_WINDOW=600    # window in seconds

# Optional: durable rate limiting across serverless instances (Vercel KV / Upstash Redis).
# Without these, rate limiting is best-effort per-instance (fine for a demo; add KV for launch).
# For local `vercel dev`, paste the store's REST credentials here (use the read-WRITE token,
# NOT the read-only one). On Vercel deploys, the Marketplace integration injects these
# automatically (prefixed with the store name, e.g. WEBO_MONEY_WORLD_KV_REST_API_URL) and the
# function resolves either the generic or the prefixed name.
# KV_REST_API_URL=https://...upstash.io
# KV_REST_API_TOKEN=...
# (Upstash-native names UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN also work.)
